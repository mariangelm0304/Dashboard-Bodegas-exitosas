            <tbody id="reportTbody"><tr onclick="navigate(&#39;detalle&#39;,&#39;t16&#39;)"><td style="color:var(--text4)">1</td><td style="font-weight:600;color:var(--text)">Jamar Norte Bogotá</td><td style="color:var(--text3)">Miguel Buitrago</td><td style="text-align:center;color:var(--text3)">4</td><td style="text-align:center;color:var(--green);font-weight:600">3</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill yellow" style="width:79%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--yellow);width:34px;text-align:right">79%</span></div></td></tr><tr onclick="navigate(&#39;detalle&#39;,&#39;t11&#39;)"><td style="color:var(--text4)">2</td><td style="font-weight:600;color:var(--text)">Jamar Norte</td><td style="color:var(--text3)">Milton Mercado</td><td style="text-align:center;color:var(--text3)">4</td><td style="text-align:center;color:var(--green);font-weight:600">3</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill yellow" style="width:75%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--yellow);width:34px;text-align:right">75%</span></div></td></tr><tr onclick="navigate(&#39;detalle&#39;,&#39;t19&#39;)"><td style="color:var(--text4)">3</td><td style="font-weight:600;color:var(--text)">Jamar CRA 30</td><td style="color:var(--text3)">Diego Valero</td><td style="text-align:center;color:var(--text3)">4</td><td style="text-align:center;color:var(--green);font-weight:600">2</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill yellow" style="width:57%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--yellow);width:34px;text-align:right">57%</span></div></td></tr><tr onclick="navigate(&#39;detalle&#39;,&#39;t18&#39;)"><td style="color:var(--text4)">4</td><td style="font-weight:600;color:var(--text)">Jamar El Edén</td><td style="color:var(--text3)">Camilo León</td><td style="text-align:center;color:var(--text3)">4</td><td style="text-align:center;color:var(--green);font-weight:600">2</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill yellow" style="width:50%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--yellow);width:34px;text-align:right">50%</span></div></td></tr><tr onclick="navigate(&#39;detalle&#39;,&#39;t0&#39;)"><td style="color:var(--text4)">5</td><td style="font-weight:600;color:var(--text)">Principal</td><td style="color:var(--text3)">Mariano Lozano</td><td style="text-align:center;color:var(--text3)">7</td><td style="text-align:center;color:var(--green);font-weight:600">3</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill red" style="width:46%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--red);width:34px;text-align:right">46%</span></div></td></tr><tr onclick="navigate(&#39;detalle&#39;,&#39;t15&#39;)"><td style="color:var(--text4)">6</td><td style="font-weight:600;color:var(--text)">Jamar Plaza Américas</td><td style="color:var(--text3)">Álvaro Gutierrez</td><td style="text-align:center;color:var(--text3)">4</td><td style="text-align:center;color:var(--green);font-weight:600">0</td><td><div class="td-bar"><div class="bar-inner"><div class="prog-wrap"><div class="prog-track" style="height:4px"><div class="prog-fill red" style="width:21%"></div></div></div></div><span style="font-family:&#39;Outfit&#39;,sans-serif;font-weight:800;font-size:12px;color:var(--red);width:34px;text-align:right">21%</span></div></td></tr></tbody>
