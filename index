<style>
/* ===== RESET & VARIABLES ===== */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:      #f0f4f8;
  --bg1:     #ffffff;
  --bg2:     #f8fafc;
  --bg3:     #f1f5f9;
  --bg4:     #e8edf4;
  --bg5:     #dde3ed;
  --gold:    #d97706;
  --gold-l:  #f59e0b;
  --gold-d:  #b45309;
  --gold-bg: #fffbeb;
  --text:    #0f172a;
  --text2:   #334155;
  --text3:   #64748b;
  --text4:   #94a3b8;
  --green:   #059669;
  --green-l: #10b981;
  --green-bg:#ecfdf5;
  --yellow:  #ca8a04;
  --yellow-l:#facc15;
  --yellow-bg:#fefce8;
  --red:     #dc2626;
  --red-l:   #ef4444;
  --red-bg:  #fef2f2;
  --blue:    #2563eb;
  --blue-l:  #3b82f6;
  --blue-bg: #eff6ff;
  --border:  #e2e8f0;
  --border2: #f1f5f9;
  --shadow:  0 1px 3px rgba(15,23,42,.08), 0 1px 2px rgba(15,23,42,.04);
  --shadow-md: 0 4px 12px rgba(15,23,42,.08), 0 2px 6px rgba(15,23,42,.05);
  --shadow-lg: 0 10px 30px rgba(15,23,42,.1), 0 4px 12px rgba(15,23,42,.06);
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg3)}
::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:#c4cbda}

/* ===== LAYOUT ===== */
#app{display:flex;height:100vh;overflow:hidden}
#sidebar{width:248px;min-width:248px;background:var(--bg1);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;box-shadow:2px 0 8px rgba(15,23,42,.04)}
#sidebar.collapsed{width:66px;min-width:66px}
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--bg)}
#topbar{padding:11px 24px;background:rgba(255,255,255,.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:10;box-shadow:var(--shadow)}
#content{flex:1;overflow-y:auto;padding:24px}

/* ===== SIDEBAR ===== */
.sb-logo{display:flex;align-items:center;gap:11px;padding:18px 16px;border-bottom:1px solid var(--border)}
.sb-icon-wrap{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 8px rgba(217,119,6,.3)}
.sb-logo-text{font-family:'Outfit',sans-serif}
.sb-logo-text .t1{font-weight:700;font-size:14px;color:var(--text);line-height:1.2}
.sb-logo-text .t2{font-weight:700;font-size:14px;color:var(--gold);line-height:1.2}
.sb-logo-text .t3{font-size:11px;color:var(--text4);margin-top:1px}
.sb-status{padding:9px 16px;border-bottom:1px solid var(--border2);font-size:11px;display:flex;align-items:center;gap:6px;background:var(--bg2)}
.status-dot{width:7px;height:7px;border-radius:50%}
.status-dot.saved{background:var(--green)}
.status-dot.saving{background:var(--gold-l);animation:pulse 1s infinite}
.status-dot.idle{background:var(--bg5)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
nav{flex:1;padding:10px 8px;display:flex;flex-direction:column;gap:2px;overflow-y:auto}
.nav-section{font-size:10px;font-weight:700;color:var(--text4);padding:10px 10px 4px;text-transform:uppercase;letter-spacing:.1em}
.nav-btn{width:100%;display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;background:none;border:none;color:var(--text3);cursor:pointer;font-size:13px;font-family:'DM Sans',sans-serif;font-weight:500;transition:all .15s;text-align:left}
.nav-btn:hover{background:var(--bg3);color:var(--text2)}
.nav-btn.active{background:var(--gold-bg);color:var(--gold-d);border:1px solid rgba(217,119,6,.2);font-weight:600}
.nav-btn svg{flex-shrink:0;opacity:.75}
.nav-btn.active svg{opacity:1}
.sb-kpis{padding:12px;border-top:1px solid var(--border);background:var(--bg2)}
.sb-kpi-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px}
.sb-kpi{border-radius:9px;padding:8px 4px;text-align:center}
.sb-kpi.g{background:var(--green-bg);border:1px solid rgba(5,150,105,.2)}
.sb-kpi.y{background:var(--yellow-bg);border:1px solid rgba(202,138,4,.2)}
.sb-kpi.r{background:var(--red-bg);border:1px solid rgba(220,38,38,.2)}
.sb-kpi .n{font-family:'Outfit',sans-serif;font-size:20px;font-weight:800;line-height:1}
.sb-kpi.g .n{color:var(--green)}
.sb-kpi.y .n{color:var(--yellow)}
.sb-kpi.r .n{color:var(--red)}
.sb-kpi .l{font-size:10px;color:var(--text4);margin-top:2px}
.sb-global{background:linear-gradient(135deg,var(--gold-bg),#fef3c7);border:1px solid rgba(217,119,6,.2);border-radius:10px;padding:10px;text-align:center}
.sb-global .pct{font-family:'Outfit',sans-serif;font-size:28px;font-weight:800;color:var(--gold-d);line-height:1}
.sb-global .lbl{font-size:11px;color:var(--gold-d);opacity:.7;margin-top:2px}
.sb-collapse{width:100%;padding:10px;background:none;border:none;border-top:1px solid var(--border);color:var(--text4);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:color .15s}
.sb-collapse:hover{color:var(--text2)}
#sidebar.collapsed .hide-collapsed{display:none}
#sidebar.collapsed .nav-btn{justify-content:center;padding:9px}

/* ===== TOPBAR ===== */
.breadcrumb{display:flex;align-items:center;gap:7px;font-size:12px;color:var(--text4)}
.breadcrumb .sep{color:var(--bg5)}
.breadcrumb span.active{color:var(--text2);font-weight:500}
.tb-right{display:flex;align-items:center;gap:10px}
.tb-badge{display:flex;align-items:center;gap:6px;background:var(--gold-bg);border:1px solid rgba(217,119,6,.25);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;color:var(--gold-d)}
.tb-dot{width:6px;height:6px;border-radius:50%;background:var(--gold-l)}
.tb-date{font-size:12px;color:var(--text4)}

/* ===== VIEWS ===== */
.view{display:none;animation:fadeIn .25s ease-out}
.view.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.page-header{margin-bottom:22px}
.page-header h1{font-family:'Outfit',sans-serif;font-size:22px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:10px}
.page-header h1::before{content:'';display:block;width:4px;height:26px;border-radius:2px;background:linear-gradient(to bottom,var(--gold-l),var(--gold-d))}
.page-header p{font-size:13px;color:var(--text3);margin-top:4px;padding-left:14px}

/* ===== CARDS ===== */
.card{background:var(--bg1);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow)}

/* ===== KPI GRID ===== */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:22px}
.kpi-card{background:var(--bg1);border-radius:14px;padding:18px 18px 16px;border:1px solid var(--border);box-shadow:var(--shadow);transition:box-shadow .2s,transform .2s;position:relative;overflow:hidden}
.kpi-card:hover{box-shadow:var(--shadow-md);transform:translateY(-1px)}
.kpi-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:14px 14px 0 0}
.kpi-card.gold::after{background:linear-gradient(90deg,var(--gold-l),var(--gold-d))}
.kpi-card.blue::after{background:linear-gradient(90deg,#60a5fa,var(--blue))}
.kpi-card.green::after{background:linear-gradient(90deg,var(--green-l),var(--green))}
.kpi-card.teal::after{background:linear-gradient(90deg,#67e8f9,#0891b2)}
.kpi-card.slate::after{background:linear-gradient(90deg,#94a3b8,#64748b)}
.kpi-card.red::after{background:linear-gradient(90deg,var(--red-l),var(--red))}
.kpi-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:18px}
.kpi-card.gold .kpi-icon{background:var(--gold-bg);border:1px solid rgba(217,119,6,.2)}
.kpi-card.blue .kpi-icon{background:var(--blue-bg);border:1px solid rgba(37,99,235,.15)}
.kpi-card.green .kpi-icon{background:var(--green-bg);border:1px solid rgba(5,150,105,.15)}
.kpi-card.teal .kpi-icon{background:#ecfeff;border:1px solid rgba(14,165,233,.15)}
.kpi-card.slate .kpi-icon{background:#f8fafc;border:1px solid rgba(100,116,139,.15)}
.kpi-card.red .kpi-icon{background:var(--red-bg);border:1px solid rgba(220,38,38,.15)}
.kpi-val{font-family:'Outfit',sans-serif;font-size:32px;font-weight:800;line-height:1}
.kpi-card.gold .kpi-val{color:var(--gold-d)}
.kpi-card.blue .kpi-val{color:var(--blue)}
.kpi-card.green .kpi-val{color:var(--green)}
.kpi-card.teal .kpi-val{color:#0891b2}
.kpi-card.slate .kpi-val{color:var(--text2)}
.kpi-card.red .kpi-val{color:var(--red)}
.kpi-title{font-size:13px;color:var(--text2);margin-top:5px;font-weight:500}
.kpi-sub{font-size:11px;color:var(--text4);margin-top:2px}

/* ===== PROGRESS BAR ===== */
.prog-wrap{width:100%}
.prog-track{height:6px;background:var(--bg4);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;transition:width .7s ease}
.prog-fill.green{background:linear-gradient(90deg,var(--green-l),var(--green))}
.prog-fill.yellow{background:linear-gradient(90deg,var(--yellow-l),var(--yellow))}
.prog-fill.red{background:linear-gradient(90deg,var(--red-l),var(--red))}
.prog-lbl{text-align:right;font-size:11px;font-weight:700;margin-top:3px;font-family:'Outfit',sans-serif}
.prog-lbl.green{color:var(--green)}
.prog-lbl.yellow{color:var(--yellow)}
.prog-lbl.red{color:var(--red)}

/* ===== SEMAPHORE ===== */
.sem-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.sem-dot.green{background:var(--green);box-shadow:0 0 0 3px rgba(5,150,105,.15)}
.sem-dot.yellow{background:var(--yellow-l);box-shadow:0 0 0 3px rgba(250,204,21,.2)}
.sem-dot.red{background:var(--red);box-shadow:0 0 0 3px rgba(220,38,38,.15)}

/* ===== STORE CARDS ===== */
.stores-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
.store-card{background:var(--bg1);border:1px solid var(--border);border-radius:14px;padding:16px;cursor:pointer;transition:all .18s;box-shadow:var(--shadow);position:relative;overflow:hidden}
.store-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:14px 0 0 14px}
.store-card.green-card::before{background:linear-gradient(to bottom,var(--green-l),var(--green))}
.store-card.yellow-card::before{background:linear-gradient(to bottom,var(--yellow-l),var(--yellow))}
.store-card.red-card::before{background:linear-gradient(to bottom,var(--red-l),var(--red))}
.store-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);border-color:#d1dae8}
.store-card .sc-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;padding-left:6px}
.store-card .sc-name{font-family:'Outfit',sans-serif;font-weight:700;font-size:14px;color:var(--text);line-height:1.3;flex:1;padding-right:8px}
.store-card:hover .sc-name{color:var(--gold-d)}
.store-card .sc-circle{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Outfit',sans-serif;font-size:13px;font-weight:800;flex-shrink:0}
.store-card .sc-circle.green{background:var(--green-bg);color:var(--green);border:2px solid rgba(5,150,105,.25)}
.store-card .sc-circle.yellow{background:var(--yellow-bg);color:var(--yellow);border:2px solid rgba(202,138,4,.3)}
.store-card .sc-circle.red{background:var(--red-bg);color:var(--red);border:2px solid rgba(220,38,38,.25)}
.sc-resp{font-size:11px;color:var(--text4);display:flex;align-items:center;gap:4px;margin-bottom:10px;cursor:pointer;padding-left:6px}
.sc-resp:hover{color:var(--text2)}
.sc-foot{display:flex;align-items:center;justify-content:space-between;margin-top:10px;padding-left:6px}
.sc-acts{font-size:11px;color:var(--text4)}

/* ===== CHARTS ===== */
.charts-row{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:22px}
.chart-card{background:var(--bg1);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow)}
.chart-title{font-family:'Outfit',sans-serif;font-size:14px;font-weight:700;color:var(--text);margin-bottom:16px}
.donuts-col{display:flex;flex-direction:column;gap:14px}
canvas{max-height:280px}

/* ===== STORE DETAIL ===== */
.detail-header{display:flex;align-items:center;gap:14px;margin-bottom:22px}
.back-btn{width:38px;height:38px;background:var(--bg1);border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text3);transition:all .15s;flex-shrink:0;box-shadow:var(--shadow)}
.back-btn:hover{color:var(--text);border-color:#c4cbda;box-shadow:var(--shadow-md)}
.detail-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px}
.ds-card{background:var(--bg1);border:1px solid var(--border);border-radius:12px;padding:16px;box-shadow:var(--shadow)}
.ds-num{font-family:'Outfit',sans-serif;font-size:32px;font-weight:800;line-height:1}
.ds-lbl{font-size:12px;color:var(--text4);margin-top:4px}

/* ===== ACTIVITIES ===== */
.acts-card{background:var(--bg1);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow)}
.acts-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.acts-title{font-family:'Outfit',sans-serif;font-size:15px;font-weight:700;color:var(--text)}
.acts-meta{font-size:12px;color:var(--text4)}
.act-row{background:var(--bg2);border:1px solid var(--border);border-radius:10px;margin-bottom:8px;overflow:hidden;transition:border-color .2s,box-shadow .2s}
.act-row:hover{border-color:#d1dae8;box-shadow:var(--shadow)}
.act-row.completada{background:var(--green-bg);border-color:rgba(5,150,105,.15)}
.act-main{display:flex;align-items:center;gap:12px;padding:11px 14px;cursor:pointer}
.act-toggle{width:22px;height:22px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .2s}
.act-toggle.pendiente{border-color:var(--bg5)}
.act-toggle.pendiente:hover{border-color:var(--text3)}
.act-toggle.en_proceso{border-color:var(--blue-l);background:var(--blue-bg)}
.act-toggle.completada{border-color:var(--green);background:var(--green)}
.act-info{flex:1;min-width:0}
.act-name{font-size:13px;font-weight:500;color:var(--text)}
.act-row.completada .act-name{color:var(--text4);text-decoration:line-through}
.act-badges{display:flex;align-items:center;gap:5px;margin-top:4px;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600;border:1px solid}
.badge.estado-pendiente{background:#f8fafc;border-color:var(--border);color:var(--text3)}
.badge.estado-en_proceso{background:var(--blue-bg);border-color:rgba(37,99,235,.2);color:var(--blue)}
.badge.estado-completada{background:var(--green-bg);border-color:rgba(5,150,105,.2);color:var(--green)}
.badge.prio-baja{background:#f8fafc;border-color:transparent;color:var(--text4)}
.badge.prio-media{background:var(--blue-bg);border-color:transparent;color:var(--blue)}
.badge.prio-alta{background:var(--yellow-bg);border-color:transparent;color:var(--yellow)}
.badge.prio-critica{background:var(--red-bg);border-color:transparent;color:var(--red)}
.act-prog{width:90px;flex-shrink:0}
.act-actions{display:flex;align-items:center;gap:2px}
.act-btn{width:28px;height:28px;background:none;border:none;color:var(--text4);cursor:pointer;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all .15s;font-size:13px}
.act-btn:hover.edit{color:var(--gold-d);background:var(--gold-bg)}
.act-btn:hover.del{color:var(--red);background:var(--red-bg)}
.act-expand{width:22px;height:22px;background:none;border:none;color:var(--text4);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .2s;font-size:11px}
.act-expand.open{transform:rotate(180deg)}
.act-detail{padding:0 14px 14px;border-top:1px solid var(--border);display:none}
.act-detail.open{display:block;animation:fadeIn .2s ease-out}
.act-detail-row{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:var(--text3)}
.act-slider-wrap{display:flex;align-items:center;gap:10px;margin-top:10px}
.act-slider-wrap label{font-size:11px;color:var(--text4);width:85px;flex-shrink:0}
.act-slider-wrap input[type=range]{flex:1;accent-color:var(--gold-d)}
.act-slider-wrap span{font-size:12px;font-weight:700;color:var(--gold-d);font-family:'Outfit',sans-serif;width:35px;text-align:right}
.empty-acts{text-align:center;padding:48px 16px}
.empty-acts .ei{font-size:40px;margin-bottom:12px;opacity:.35}
.empty-acts p{color:var(--text4);font-size:13px;margin-bottom:16px}

/* ===== TABLE ===== */
.filter-bar{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.search-wrap{position:relative;flex:1;min-width:200px;max-width:300px}
.search-wrap input{width:100%;background:var(--bg1);border:1px solid var(--border);color:var(--text);border-radius:10px;padding:8px 12px 8px 36px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;box-shadow:var(--shadow)}
.search-wrap input:focus{border-color:rgba(217,119,6,.5);box-shadow:0 0 0 3px rgba(217,119,6,.08)}
.search-wrap input::placeholder{color:var(--text4)}
.search-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text4);font-size:14px}
.filter-pills{display:flex;gap:6px;flex-wrap:wrap}
.pill{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;border:1px solid var(--border);background:var(--bg1);color:var(--text3);cursor:pointer;transition:all .15s;box-shadow:var(--shadow)}
.pill.active{background:var(--gold-bg);border-color:rgba(217,119,6,.3);color:var(--gold-d);font-weight:600}
.pill:hover:not(.active){background:var(--bg3);color:var(--text2)}
.table-wrap{background:var(--bg1);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow)}
table{width:100%;border-collapse:collapse}
thead tr{border-bottom:1px solid var(--border);background:var(--bg2)}
th{text-align:left;padding:11px 16px;font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;cursor:pointer;user-select:none;white-space:nowrap}
th:hover{color:var(--text2)}
tbody tr{border-bottom:1px solid var(--border2);cursor:pointer;transition:background .1s}
tbody tr:hover{background:var(--bg2)}
tbody tr:last-child{border-bottom:none}
td{padding:11px 16px;font-size:13px}
.td-bar{display:flex;align-items:center;gap:10px;min-width:140px}
.td-bar .bar-inner{flex:1}

/* ===== REPORTS ===== */
.report-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:22px}
.rstat{background:var(--bg1);border:1px solid var(--border);border-radius:12px;padding:18px;box-shadow:var(--shadow)}
.rstat .rv{font-family:'Outfit',sans-serif;font-size:32px;font-weight:800;color:var(--text);line-height:1}
.rstat .rl{font-size:13px;color:var(--gold-d);font-weight:600;margin-top:4px}
.rstat .rs{font-size:11px;color:var(--text4);margin-top:2px}
.top-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:22px}
.top-card{background:var(--bg1);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow)}
.top-card-title{font-family:'Outfit',sans-serif;font-size:14px;font-weight:700;color:var(--text);margin-bottom:16px}
.top-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.top-rank{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;font-family:'Outfit',sans-serif}
