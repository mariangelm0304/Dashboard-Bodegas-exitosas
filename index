<script>
// ===== STATE =====
const TIENDAS_NAMES=['Principal','Cuatro Vientos','Bucaramanga','Jamar Metropolitano','Jamar Riohacha','Valledupar Loperena','Montería','Jamar Sincelejo','Jamar San Felipe','Jamar La Plazuela','Santa Marta','Jamar Norte','Mayorca CC Medellín','Molinos CC Medellín','Jamar CC Florida','Jamar Plaza Américas','Jamar Norte Bogotá','Jamar Fabricato','Jamar El Edén','Jamar CRA 30','Hiperjamar'];
let state={tiendas:[],actividades:[]};
let currentTiendaId=null,currentFilter='all',sortCol='nombre',sortDir='asc';
let modalEstado='pendiente',modalPrio='media';
let chartBar=null,chartDonut1=null,chartDonut2=null,chartBarFull=null;

// ===== STORAGE =====
function save(){try{localStorage.setItem('bodegas_v2',JSON.stringify(state));}catch(e){}setSaved();}
function load(){try{const d=localStorage.getItem('bodegas_v2');if(d){state=JSON.parse(d);return;}}catch(e){}initDemo();}
function initDemo(){
  state.tiendas=TIENDAS_NAMES.map((n,i)=>({id:'t'+i,nombre:n,responsable:'',orden:i}));
  state.actividades=[];
  const acts=['Organización de bodega','Inventario físico','Señalización de zonas','Capacitación personal','Implementación 5S'];
  const estArr=['pendiente','en_proceso','completada'];
  state.tiendas.forEach((t,ti)=>{
    const n=3+Math.floor(Math.random()*3);
    for(let i=0;i<n;i++){
      const est=estArr[Math.floor(Math.random()*3)];
      const pct=est==='completada'?100:est==='en_proceso'?20+Math.floor(Math.random()*65):Math.floor(Math.random()*25);
      state.actividades.push({id:'a'+ti+'_'+i,tienda_id:t.id,nombre:acts[i%acts.length],estado:est,prioridad:['baja','media','alta','critica'][Math.floor(Math.random()*4)],porcentaje:pct,comentarios:'',fecha_limite:'',created:Date.now()});
    }
  });
  save();
}

// ===== HELPERS =====
function uid(){return 'id_'+Math.random().toString(36).slice(2)+'_'+Date.now();}
function semaforo(p){return p>=80?'green':p>=50?'yellow':'red';}
function semaforoLabel(p){return p>=80?'Óptimo':p>=50?'En progreso':'Crítico';}
function semaforoColor(p){return p>=80?'var(--green)':p>=50?'var(--yellow)':'var(--red)';}
function calcAvance(tid){const a=state.actividades.filter(x=>x.tienda_id===tid);return a.length?Math.round(a.reduce((s,x)=>s+(x.porcentaje||0),0)/a.length):0;}
function getTienda(id){return state.tiendas.find(t=>t.id===id);}
function getTiendaActs(id){return state.actividades.filter(a=>a.tienda_id===id);}
function getTiendasWithAvance(){return state.tiendas.map(t=>({...t,avance:calcAvance(t.id),actividades:getTiendaActs(t.id)}));}
function kpis(){
  const ts=getTiendasWithAvance(),acts=state.actividades;
  return{totalTiendas:ts.length,avanceGlobal:ts.length?Math.round(ts.reduce((s,t)=>s+t.avance,0)/ts.length):0,completadas:acts.filter(a=>a.estado==='completada').length,enProceso:acts.filter(a=>a.estado==='en_proceso').length,pendientes:acts.filter(a=>a.estado==='pendiente').length,total:acts.length,verde:ts.filter(t=>t.avance>=80).length,amarillo:ts.filter(t=>t.avance>=50&&t.avance<80).length,rojo:ts.filter(t=>t.avance<50).length};
}

// ===== STATUS =====
function setSaving(){document.getElementById('statusDot').className='status-dot saving';document.getElementById('statusTxt').textContent='Guardando...';document.getElementById('statusTxt').style.color='var(--gold-d)';}
function setSaved(){document.getElementById('statusDot').className='status-dot saved';document.getElementById('statusTxt').textContent='Guardado '+new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit'});document.getElementById('statusTxt').style.color='var(--green)';}
function toast(msg){const el=document.createElement('div');el.className='toast-item success';el.textContent=msg;document.getElementById('toast').appendChild(el);setTimeout(()=>el.remove(),3000);}
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('collapsed');}
function toggleMobileMenu(){const s=document.getElementById('sidebar');s.style.display=s.style.display==='flex'?'none':'flex';}

// ===== PROGRESS BAR =====
function progressBar(p,showLabel=true,h='6px'){
  const s=semaforo(p);
  return `<div class="prog-wrap"><div class="prog-track" style="height:${h}"><div class="prog-fill ${s}" style="width:${p}%"></div></div>${showLabel?`<div class="prog-lbl ${s}">${p}%</div>`:''}</div>`;
}
function semDot(p){return `<span class="sem-dot ${semaforo(p)}"></span>`;}

// ===== NAVIGATION =====
function navigate(view,tiendaId=null){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  const labels={dashboard:'Dashboard',tiendas:'Tiendas',reportes:'Reportes',detalle:'Detalle Tienda'};
  if(view==='detalle'&&tiendaId){
    currentTiendaId=tiendaId;
    document.getElementById('view-detalle').classList.add('active');
    document.getElementById('nav-tiendas').classList.add('active');
    document.getElementById('breadcrumbLabel').textContent=getTienda(tiendaId)?.nombre||'Tienda';
    renderDetalle();
  }else{
    document.getElementById('view-'+view).classList.add('active');
    document.getElementById('nav-'+view)?.classList.add('active');
    document.getElementById('breadcrumbLabel').textContent=labels[view]||view;
    if(view==='dashboard')renderDashboard();
    else if(view==='tiendas')renderTiendasTable();
    else if(view==='reportes')renderReportes();
  }
  updateSidebar();
}
function updateSidebar(){
  const k=kpis();
  document.getElementById('sb-verde').textContent=k.verde;
  document.getElementById('sb-amarillo').textContent=k.amarillo;
  document.getElementById('sb-rojo').textContent=k.rojo;
  document.getElementById('sb-global').textContent=k.avanceGlobal+'%';
  document.getElementById('globalBadge').textContent=k.avanceGlobal+'% global';
}

// ===== DASHBOARD =====
function renderDashboard(){renderKPIs();renderStoresGrid();renderCharts();}
function renderKPIs(){
  const k=kpis();
  const cards=[
    {title:'Avance Global',val:k.avanceGlobal,suf:'%',sub:k.totalTiendas+' tiendas',icon:'📈',c:'gold'},
    {title:'Tiendas Activas',val:k.totalTiendas,sub:'registradas',icon:'🏪',c:'blue'},
    {title:'Completadas',val:k.completadas,sub:'de '+k.total+' total',icon:'✅',c:'green'},
    {title:'En Proceso',val:k.enProceso,sub:'actividades',icon:'⚡',c:'teal'},
    {title:'Pendientes',val:k.pendientes,sub:'sin iniciar',icon:'⏳',c:'slate'},
    {title:'Tiendas en Rojo',val:k.rojo,sub:'críticas',icon:'⚠️',c:'red'},
  ];
  document.getElementById('kpiGrid').innerHTML=cards.map(c=>`<div class="kpi-card ${c.c}"><div class="kpi-icon">${c.icon}</div><div class="kpi-val">${c.val}${c.suf||''}</div><div class="kpi-title">${c.title}</div><div class="kpi-sub">${c.sub}</div></div>`).join('');
}
function renderStoresGrid(){
  const ts=getTiendasWithAvance();
  document.getElementById('storesGrid').innerHTML=ts.map(t=>`
    <div class="store-card ${semaforo(t.avance)}-card" onclick="navigate('detalle','${t.id}')">
      <button class="sc-delete" onclick="event.stopPropagation();deleteTienda('${t.id}')" title="Eliminar tienda">🗑</button>
      <div class="sc-top">
        <div>
          <div class="sc-name">${t.nombre}</div>
          <div class="sc-resp resp-display" onclick="event.stopPropagation();startEditResp('${t.id}',this)">📍 <span>${t.responsable||'Sin responsable'}</span> ✏️</div>
        </div>
        <div class="sc-circle ${semaforo(t.avance)}">${t.avance}%</div>
      </div>
      ${progressBar(t.avance,false,'5px')}
      <div class="sc-foot">
        <div style="display:flex;align-items:center;gap:6px">${semDot(t.avance)}<span style="font-size:11px;color:${semaforoColor(t.avance)};font-weight:600">${semaforoLabel(t.avance)}</span></div>
        <span class="sc-acts">${t.actividades.length} act. →</span>
      </div>
    </div>`).join('')+`
    <button class="add-store-btn" onclick="openTiendaModal()">
      <span class="plus">＋</span>
      <span>Agregar nueva tienda</span>
    </button>`;
}
function renderCharts(){
  const ts=getTiendasWithAvance().sort((a,b)=>b.avance-a.avance).slice(0,10),k=kpis();
  if(chartBar)chartBar.destroy();
  chartBar=new Chart(document.getElementById('chartBar').getContext('2d'),{
    type:'bar',
    data:{labels:ts.map(t=>t.nombre.length>18?t.nombre.slice(0,15)+'…':t.nombre),datasets:[{data:ts.map(t=>t.avance),backgroundColor:ts.map(t=>t.avance>=80?'rgba(5,150,105,.75)':t.avance>=50?'rgba(202,138,4,.75)':'rgba(220,38,38,.75)'),borderRadius:5,borderSkipped:false}]},
    options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` ${c.raw}%`}}},scales:{x:{grid:{color:'rgba(226,232,240,.7)'},ticks:{color:'#94a3b8',callback:v=>v+'%'},max:100},y:{grid:{display:false},ticks:{color:'#475569',font:{size:11}}}}}
  });
  if(chartDonut1)chartDonut1.destroy();
  const d1f=[k.verde,k.amarillo,k.rojo].filter(v=>v>0);
  const d1l=['Verde (≥80%)','Amarillo (50-79%)','Rojo (<50%)'].filter((_,i)=>[k.verde,k.amarillo,k.rojo][i]>0);
  const d1c=['rgba(5,150,105,.8)','rgba(202,138,4,.85)','rgba(220,38,38,.8)'].filter((_,i)=>[k.verde,k.amarillo,k.rojo][i]>0);
  chartDonut1=new Chart(document.getElementById('chartDonut1').getContext('2d'),{type:'doughnut',data:{labels:d1l,datasets:[{data:d1f,backgroundColor:d1c,borderWidth:2,borderColor:'#fff',hoverOffset:4}]},options:{plugins:{legend:{position:'bottom',labels:{color:'#64748b',font:{size:11},boxWidth:8,padding:12}}},cutout:'65%'}});
  if(chartDonut2)chartDonut2.destroy();
  chartDonut2=new Chart(document.getElementById('chartDonut2').getContext('2d'),{type:'doughnut',data:{labels:['Completadas','En Proceso','Pendientes'],datasets:[{data:[k.completadas,k.enProceso,k.pendientes],backgroundColor:['rgba(5,150,105,.8)','rgba(37,99,235,.8)','rgba(148,163,184,.6)'],borderWidth:2,borderColor:'#fff',hoverOffset:4}]},options:{plugins:{legend:{position:'bottom',labels:{color:'#64748b',font:{size:11},boxWidth:8,padding:12}}},cutout:'65%'}});
}

// ===== INLINE RESP =====
function startEditResp(tiendaId,el){
  const t=getTienda(tiendaId);
  el.outerHTML=`<div class="resp-input-wrap" id="resp_${tiendaId}"><input class="resp-input" id="respInp_${tiendaId}" value="${t.responsable||''}" placeholder="Responsable..."><button onclick="event.stopPropagation();saveResp('${tiendaId}')" style="background:none;border:none;color:var(--green);cursor:pointer;font-size:15px;font-weight:700">✓</button><button onclick="event.stopPropagation();renderStoresGrid()" style="background:none;border:none;color:var(--text4);cursor:pointer;font-size:15px">✕</button></div>`;
  setTimeout(()=>document.getElementById('respInp_'+tiendaId)?.focus(),0);
}
function saveResp(tiendaId){
  const val=document.getElementById('respInp_'+tiendaId)?.value||'';
  const t=getTienda(tiendaId);
  if(t){t.responsable=val;save();toast('Responsable actualizado');}
  renderStoresGrid();
}

// ===== TABLE =====
function setFilter(f){currentFilter=f;document.querySelectorAll('.pill').forEach(p=>p.classList.toggle('active',p.dataset.filter===f));renderTiendasTable();}
function sortTable(col){if(sortCol===col)sortDir=sortDir==='asc'?'desc':'asc';else{sortCol=col;sortDir='asc';}renderTiendasTable();}
function renderTiendasTable(){
  const search=(document.getElementById('searchInput')?.value||'').toLowerCase();
  let ts=getTiendasWithAvance();
  if(currentFilter==='verde')ts=ts.filter(t=>t.avance>=80);
  else if(currentFilter==='amarillo')ts=ts.filter(t=>t.avance>=50&&t.avance<80);
  else if(currentFilter==='rojo')ts=ts.filter(t=>t.avance<50);
  if(search)ts=ts.filter(t=>t.nombre.toLowerCase().includes(search)||(t.responsable||'').toLowerCase().includes(search));
  ts.sort((a,b)=>{let va=a[sortCol]||0,vb=b[sortCol]||0;if(typeof va==='string'){va=va.toLowerCase();vb=vb.toLowerCase();}return sortDir==='asc'?(va>vb?1:-1):(va<vb?1:-1);});
  document.getElementById('tiendasTbody').innerHTML=ts.map(t=>`
    <tr onclick="navigate('detalle','${t.id}')">
      <td><div style="display:flex;align-items:center;gap:10px"><div style="width:3px;height:30px;border-radius:2px;background:${semaforoColor(t.avance)};flex-shrink:0"></div><span style="font-weight:600;color:var(--text)">${t.nombre}</span></div></td>
      <td style="color:var(--text3)">${t.responsable||'—'}</td>
      <td><div class="td-bar"><div class="bar-inner">${progressBar(t.avance,false,'5px')}</div><span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:13px;color:${semaforoColor(t.avance)};width:38px;text-align:right">${t.avance}%</span></div></td>
      <td><div style="display:flex;align-items:center;gap:6px">${semDot(t.avance)}<span style="font-size:12px;color:${semaforoColor(t.avance)};font-weight:600">${semaforoLabel(t.avance)}</span></div></td>
      <td style="text-align:right"><span style="background:var(--bg3);padding:3px 9px;border-radius:20px;font-size:12px;color:var(--text3);font-weight:500">${t.actividades.length}</span></td>
      <td style="text-align:center"><button onclick="event.stopPropagation();deleteTienda('${t.id}')" style="background:none;border:none;color:var(--text4);cursor:pointer;border-radius:6px;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;font-size:14px;transition:all .15s" onmouseover="this.style.color='var(--red)';this.style.background='var(--red-bg)'" onmouseout="this.style.color='var(--text4)';this.style.background='none'" title="Eliminar tienda">🗑</button></td>
    </tr>`).join('');
}

// ===== DETALLE =====
function renderDetalle(){
  const t=getTienda(currentTiendaId);if(!t)return;
  const avance=calcAvance(t.id),acts=getTiendaActs(t.id),compl=acts.filter(a=>a.estado==='completada').length,sc=semaforoColor(avance);
  document.getElementById('detalleName').textContent=t.nombre;
  document.getElementById('detalleResp').textContent=t.responsable||'Sin responsable asignado';
  document.getElementById('editingTiendaId').value=t.id;
  document.getElementById('detailStats').innerHTML=`
    <div class="ds-card" style="border-top:3px solid ${sc}"><div class="ds-num" style="color:${sc}">${avance}%</div><div class="ds-lbl">Avance general</div>${progressBar(avance,false,'4px')}</div>
    <div class="ds-card"><div class="ds-num" style="color:var(--text)">${acts.length}</div><div class="ds-lbl">Actividades</div></div>
    <div class="ds-card" style="border-top:3px solid var(--green)"><div class="ds-num" style="color:var(--green)">${compl}</div><div class="ds-lbl">Completadas</div></div>
    <div class="ds-card" style="display:flex;align-items:center;gap:12px">${semDot(avance)}<div><div style="font-size:13px;color:${sc};font-weight:700">${semaforoLabel(avance)}</div><div class="ds-lbl">Estado</div></div></div>`;
  document.getElementById('actsMeta').textContent=`${compl}/${acts.length} completadas`;
  renderActsList();
}
function renderActsList(){
  const acts=getTiendaActs(currentTiendaId),el=document.getElementById('actsList');
  if(!acts.length){el.innerHTML=`<div class="empty-acts"><div class="ei">📋</div><p>No hay actividades registradas</p><button class="btn-primary" onclick="openModal()">＋ Crear primera actividad</button></div>`;return;}
  el.innerHTML=acts.map(a=>`
    <div class="act-row ${a.estado}" id="arow_${a.id}">
      <div class="act-main" onclick="toggleActExpand('${a.id}')">
        <div class="act-toggle ${a.estado}" onclick="event.stopPropagation();cycleEstado('${a.id}')" title="Cambiar estado">${a.estado==='completada'?'<span style="color:#fff;font-size:10px;font-weight:900">✓</span>':a.estado==='en_proceso'?'<span style="color:var(--blue);font-size:10px">●</span>':''}</div>
        <div class="act-info">
          <div class="act-name">${a.nombre}</div>
          <div class="act-badges">
            <span class="badge estado-${a.estado}">${{pendiente:'Pendiente',en_proceso:'En Proceso',completada:'Completada'}[a.estado]}</span>
            <span class="badge prio-${a.prioridad}">${{baja:'Baja',media:'Media',alta:'Alta',critica:'Crítica'}[a.prioridad]}</span>
            ${a.fecha_limite?`<span class="badge" style="background:var(--bg3);border-color:var(--border);color:var(--text4)">📅 ${a.fecha_limite}</span>`:''}
          </div>
        </div>
        <div class="act-prog" onclick="event.stopPropagation()">${progressBar(a.porcentaje,false,'5px')}<div style="text-align:right;font-size:11px;color:var(--text4);margin-top:2px;font-family:'Outfit',sans-serif;font-weight:600">${a.porcentaje}%</div></div>
        <div class="act-actions" onclick="event.stopPropagation()">
          <button class="act-btn edit" onclick="editAct('${a.id}')" title="Editar">✏️</button>
          <button class="act-btn del" onclick="deleteAct('${a.id}')" title="Eliminar">🗑️</button>
          <button class="act-expand" id="exp_${a.id}" onclick="event.stopPropagation();toggleActExpand('${a.id}')">▼</button>
        </div>
      </div>
      <div class="act-detail" id="det_${a.id}">
        ${a.comentarios?`<div class="act-detail-row">💬 <span>${a.comentarios}</span></div>`:''}
        <div class="act-slider-wrap">
          <label>Ajustar avance</label>
          <input type="range" min="0" max="100" step="5" value="${a.porcentaje}" oninput="quickPct('${a.id}',this.value)">
          <span id="sliderVal_${a.id}">${a.porcentaje}%</span>
        </div>
      </div>
    </div>`).join('');
}
function toggleActExpand(id){const d=document.getElementById('det_'+id),e=document.getElementById('exp_'+id);const o=d.classList.toggle('open');e.classList.toggle('open',o);}
function cycleEstado(id){
  const a=state.actividades.find(x=>x.id===id);if(!a)return;
  const order=['pendiente','en_proceso','completada'],next=order[(order.indexOf(a.estado)+1)%3];
  a.estado=next;if(next==='completada')a.porcentaje=100;else if(next==='pendiente')a.porcentaje=0;
  save();renderDetalle();updateSidebar();
  toast(`Estado → ${{pendiente:'Pendiente',en_proceso:'En Proceso',completada:'Completada'}[next]}`);
}
function quickPct(id,val){
  const a=state.actividades.find(x=>x.id===id);if(!a)return;
  a.porcentaje=Number(val);document.getElementById('sliderVal_'+id).textContent=val+'%';
  save();updateSidebar();
  const row=document.getElementById('arow_'+id);
  if(row){const prog=row.querySelector('.act-prog');if(prog){prog.innerHTML=progressBar(a.porcentaje,false,'5px')+`<div style="text-align:right;font-size:11px;color:var(--text4);margin-top:2px;font-family:'Outfit',sans-serif;font-weight:600">${a.porcentaje}%</div>`;}}
}
function deleteAct(id){if(!confirm('¿Eliminar esta actividad?'))return;state.actividades=state.actividades.filter(a=>a.id!==id);save();renderDetalle();updateSidebar();toast('Actividad eliminada');}
function editAct(id){const a=state.actividades.find(x=>x.id===id);if(a)openModal(a);}

// ===== MODAL =====
function openModal(act=null){
  const tid=currentTiendaId,t=getTienda(tid);
  document.getElementById('editingActId').value=act?act.id:'';
  document.getElementById('editingTiendaId').value=tid;
  document.getElementById('modalTitle').textContent=act?'Editar Actividad':'Nueva Actividad';
  document.getElementById('modalStore').textContent=t?.nombre||'';
  document.getElementById('actNombre').value=act?.nombre||'';
  document.getElementById('actComentarios').value=act?.comentarios||'';
  document.getElementById('actFecha').value=act?.fecha_limite||'';
  document.getElementById('actPct').value=act?.porcentaje||0;
  updatePctLabel(act?.porcentaje||0);
  document.getElementById('saveIcon').textContent=act?'💾':'＋';
  document.getElementById('saveTxt').textContent=act?'Guardar cambios':'Crear actividad';
  modalEstado=act?.estado||'pendiente';modalPrio=act?.prioridad||'media';
  refreshEstadoBtns();refreshPrioBtns();
  document.getElementById('actModal').classList.add('open');
  setTimeout(()=>document.getElementById('actNombre').focus(),100);
}
function closeModal(){document.getElementById('actModal').classList.remove('open');}
function updatePctLabel(v){document.getElementById('pctLabel').textContent=v+'%';document.getElementById('pctVal').textContent=v+'%';}
function selectEstado(e){modalEstado=e;const p=Number(document.getElementById('actPct').value);if(e==='completada'){document.getElementById('actPct').value=100;updatePctLabel(100);}else if(e==='pendiente'&&p===100){document.getElementById('actPct').value=0;updatePctLabel(0);}refreshEstadoBtns();}
function selectPrio(p){modalPrio=p;refreshPrioBtns();}
function refreshEstadoBtns(){document.querySelectorAll('#estadoGroup .seg-btn').forEach(b=>{b.className='seg-btn';if(b.dataset.val===modalEstado)b.classList.add(modalEstado==='pendiente'?'active-pend':modalEstado==='en_proceso'?'active-proc':'active-done');});}
function refreshPrioBtns(){document.querySelectorAll('#prioGroup .seg-btn').forEach(b=>{b.className=`seg-btn prio-${b.dataset.val}`;if(b.dataset.val===modalPrio)b.classList.add('active-p');});}
function saveActividad(){
  const nombre=document.getElementById('actNombre').value.trim();
  if(!nombre){document.getElementById('actNombre').style.outline='2px solid var(--red)';return;}
  document.getElementById('actNombre').style.outline='';
  const editId=document.getElementById('editingActId').value,tiendaId=document.getElementById('editingTiendaId').value;
  const data={nombre,estado:modalEstado,prioridad:modalPrio,porcentaje:Number(document.getElementById('actPct').value),comentarios:document.getElementById('actComentarios').value.trim(),fecha_limite:document.getElementById('actFecha').value,tienda_id:tiendaId};
  if(editId){const idx=state.actividades.findIndex(a=>a.id===editId);if(idx!==-1)state.actividades[idx]={...state.actividades[idx],...data};toast('Actividad actualizada');}
  else{state.actividades.push({id:uid(),...data,created:Date.now()});toast('Actividad creada');}
  save();closeModal();renderDetalle();updateSidebar();
}

// ===== TIENDA CRUD =====
function openTiendaModal(){
  document.getElementById('tiendaNombre').value='';
  document.getElementById('tiendaResponsable').value='';
  document.getElementById('tiendaModal').classList.add('open');
  setTimeout(()=>document.getElementById('tiendaNombre').focus(),100);
}
function closeTiendaModal(){document.getElementById('tiendaModal').classList.remove('open');}
function saveTienda(){
  const nombre=document.getElementById('tiendaNombre').value.trim();
  if(!nombre){document.getElementById('tiendaNombre').style.outline='2px solid var(--red)';return;}
  document.getElementById('tiendaNombre').style.outline='';
  const responsable=document.getElementById('tiendaResponsable').value.trim();
  const maxOrden=state.tiendas.length?Math.max(...state.tiendas.map(t=>t.orden||0))+1:0;
  state.tiendas.push({id:uid(),nombre,responsable,orden:maxOrden});
  save();closeTiendaModal();
  // Refresh current view
  const active=document.querySelector('.view.active');
  if(active?.id==='view-dashboard'){renderDashboard();}
  else if(active?.id==='view-tiendas'){renderTiendasTable();}
  updateSidebar();
  toast('Tienda "'+nombre+'" agregada');
}
function deleteTienda(id){
  const t=getTienda(id);if(!t)return;
  const acts=getTiendaActs(id).length;
  const msg=acts>0
    ?`¿Eliminar "${t.nombre}"?\n\nEsta tienda tiene ${acts} actividad(es) que también se eliminarán.\n\nEsta acción no se puede deshacer.`
    :`¿Eliminar "${t.nombre}"?\n\nEsta acción no se puede deshacer.`;
  if(!confirm(msg))return;
  state.tiendas=state.tiendas.filter(x=>x.id!==id);
  state.actividades=state.actividades.filter(a=>a.tienda_id!==id);
  save();
  // If we're in the detail of this tienda, go back to tiendas
  if(currentTiendaId===id){navigate('tiendas');}
  else{
    const active=document.querySelector('.view.active');
    if(active?.id==='view-dashboard')renderDashboard();
    else if(active?.id==='view-tiendas')renderTiendasTable();
  }
  updateSidebar();
  toast('Tienda eliminada');
}

// ===== REPORTES =====
function renderReportes(){
  const k=kpis(),ts=getTiendasWithAvance(),rate=k.total?Math.round((k.completadas/k.total)*100):0;
  document.getElementById('reportStats').innerHTML=[
    {rv:rate+'%',rl:'Tasa de completitud',rs:'Actividades finalizadas'},
    {rv:k.total?(k.total/k.totalTiendas).toFixed(1):'0',rl:'Promedio por tienda',rs:'Actividades'},
    {rv:k.verde,rl:'Tiendas al objetivo',rs:'Avance ≥ 80%'},
    {rv:k.rojo,rl:'Tiendas críticas',rs:'Avance < 50%'},
  ].map(s=>`<div class="rstat"><div class="rv">${s.rv}</div><div class="rl">${s.rl}</div><div class="rs">${s.rs}</div></div>`).join('');
  const sorted=[...ts].sort((a,b)=>b.avance-a.avance);
  const top5=sorted.slice(0,5),bot5=[...ts].sort((a,b)=>a.avance-b.avance).slice(0,5);
  const topCard=(items,type)=>`<div class="top-card"><div class="top-card-title">${type==='top'?'🏆 Top 5 Tiendas':'⚠️ Tiendas Críticas'}</div>${items.map((t,i)=>`<div class="top-row"><div class="top-rank ${type==='top'?'gold':'red'}">${i+1}</div><div class="top-name">${t.nombre}</div><div class="top-pct" style="color:${semaforoColor(t.avance)}">${t.avance}%</div></div>`).join('')}</div>`;
  document.getElementById('topGrid').innerHTML=topCard(top5,'top')+topCard(bot5,'worst');
  if(chartBarFull)chartBarFull.destroy();
  const ctx=document.getElementById('chartBarFull').getContext('2d');
  chartBarFull=new Chart(ctx,{type:'bar',data:{labels:sorted.map(t=>t.nombre.length>16?t.nombre.slice(0,13)+'…':t.nombre),datasets:[{data:sorted.map(t=>t.avance),backgroundColor:sorted.map(t=>t.avance>=80?'rgba(5,150,105,.75)':t.avance>=50?'rgba(202,138,4,.75)':'rgba(220,38,38,.75)'),borderRadius:4,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` ${c.raw}%`}}},scales:{x:{grid:{color:'rgba(226,232,240,.8)'},ticks:{color:'#94a3b8',font:{size:10},maxRotation:45}},y:{grid:{color:'rgba(226,232,240,.8)'},ticks:{color:'#94a3b8',callback:v=>v+'%'},max:100}}}});
  document.getElementById('chartBarFull').style.maxHeight='300px';
  document.getElementById('reportTbody').innerHTML=sorted.map((t,i)=>{
    const compl=t.actividades.filter(a=>a.estado==='completada').length;
    return `<tr onclick="navigate('detalle','${t.id}')"><td style="color:var(--text4)">${i+1}</td><td style="font-weight:600;color:var(--text)">${t.nombre}</td><td style="color:var(--text3)">${t.responsable||'—'}</td><td style="text-align:center;color:var(--text3)">${t.actividades.length}</td><td style="text-align:center;color:var(--green);font-weight:600">${compl}</td><td><div class="td-bar"><div class="bar-inner">${progressBar(t.avance,false,'4px')}</div><span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:12px;color:${semaforoColor(t.avance)};width:34px;text-align:right">${t.avance}%</span></div></td></tr>`;
  }).join('');
}

// ===== INIT =====
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeModal();closeTiendaModal();}});
const tbDate=document.getElementById('tbDate');
if(tbDate){const now=new Date();tbDate.textContent=now.toLocaleDateString('es-CO',{weekday:'short',day:'numeric',month:'short'});}
Chart.defaults.color='#94a3b8';
Chart.defaults.borderColor='rgba(226,232,240,.8)';
Chart.defaults.font.family="'DM Sans', sans-serif";
load();
navigate('dashboard');
</script>


</body></html>
